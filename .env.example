# ============================================================
# Sales Tracker - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------

# For Docker (development):
#   DB_HOST=db
#
# For XAMPP (production):
#   DB_HOST=localhost

DB_HOST=localhost
DB_PORT=3306
DB_NAME=sales_tracker
DB_USER=root
DB_PASS=

# ------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------

# Base URL of the application (no trailing slash)
# For XAMPP in subdirectory: http://localhost/sales-tracker
# For Docker: http://localhost:8080
APP_URL=http://localhost:8080

# Application timezone (PHP timezone string)
APP_TIMEZONE=Asia/Bangkok
